# Required -- every agent runs on this model (LiteLlm(model="openai/gpt-4o-mini"))
OPENAI_API_KEY=

GITHUB_TOKEN=

# Repo paths
REPO_BITCOIN_CORE=/path/to/bitcoin

# GitHub repo slugs (owner/repo) for PR/issue lookups
GITHUB_REPO_CORE=bitcoin/bitcoin

# Postgres (see db/docker-compose.yml). Not 5432 (the Postgres default) or
# 5433 -- both commonly claimed by other local projects/containers already.
POSTGRES_USER=sabio
POSTGRES_PASSWORD=sabio
POSTGRES_DB=sabio
POSTGRES_PORT=5434
DATABASE_URL=postgresql://sabio:sabio@localhost:5434/sabio
