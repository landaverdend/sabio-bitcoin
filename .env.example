GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# Repo paths
REPO_BITCOIN_CORE=/path/to/bitcoin

# GitHub repo slugs (owner/repo) for PR/issue lookups
GITHUB_REPO_CORE=bitcoin/bitcoin

# Postgres (see db/docker-compose.yml)
POSTGRES_USER=sabio
POSTGRES_PASSWORD=sabio
POSTGRES_DB=sabio
POSTGRES_PORT=5432
DATABASE_URL=postgresql://sabio:sabio@localhost:5432/sabio
